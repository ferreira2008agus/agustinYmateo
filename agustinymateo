drop database if exist queque
create database queque
use queque

create table provincia (provincia_id int Primary key auto_increment , nombreprov varchar (50) );

create table ciudad (ciudad_id int Primary key auto_increment , provincia_id int , nombreciudad varchar (50) , 
Foreing Key (provincincia_id) reference provincia(provincia_id) );

create table producto (producto_id int Primary key auto_increment , nombreproducto varchar (60) , cantidad int );

create table pedido (pedido_id int Primary key auto_increment , producto_id int , precio int ,Foreing Key (producto_id) Reference producto(producto_id) );

create table cliente (id int Primary key auto_increment , pedido_id int , ciudad_id int , nombre varchar(40) , foreing key (ciudad_id) reference ciudad(ciudad_id) ,
foreing key (pedido_id) reference pedido(pedido_id));


